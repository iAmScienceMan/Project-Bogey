<!-- ReSharper disable All -->
<Control xmlns="clr-namespace:Lattice.Renderer.Ui.Controls;assembly=Lattice.Renderer">

  <Label Name="WaitingLabel" Anchor="TopLeft" Margin="20" FontSize="16" Color="#CCDBEB"
         Text="WAITING FOR FIRST SNAPSHOT..." />

  <BoxContainer Name="StatusReadout" Anchor="TopLeft" Orientation="Vertical" DrawBackground="false" Separation="5" Margin="16 14 16 16">
    <Label Name="TickLabel"     FontSize="15" Color="#CCDBEB" />
    <Label Name="SpeedLabel"    FontSize="15" Color="#CCDBEB" />
  </BoxContainer>

  <BoxContainer Name="ControlBar" Anchor="TopCenter" Orientation="Horizontal" Separation="7" Padding="7" Margin="14">
    <Button Name="PauseButton"    Icon="||"  Hotkey="Space" ToolTip="Pause / resume" />
    <Button Name="NormalButton"   Icon="1x"  Hotkey="1"     ToolTip="Normal speed" />
    <Button Name="FastButton"     Icon="10x" Hotkey="2"     ToolTip="Fast forward" />
    <Button Name="RecenterButton" Icon="[+]" Hotkey="C"     ToolTip="Recenter on flagship" />
  </BoxContainer>

  <BoxContainer Name="DebugPanel" Anchor="TopRight" Orientation="Vertical" Separation="7" Padding="7" Margin="14">
    <Label Text="DEBUG" />
    <Button Name="DeclutterButton" Icon="::" Hotkey="G" ToolTip="Cycle ground-truth declutter" />
  </BoxContainer>

  <BoxContainer Name="EngagePanel" Anchor="BottomLeft" Orientation="Vertical" Separation="6" Padding="9" Margin="14">
    <Label Name="EngageTitle" FontSize="14" Color="#CCDBEB" Text="UNIT" />
    <Label Name="EngageHull" FontSize="12" Color="#9FB4CC" Text="HP -" />
    <Label Name="EngageTarget" FontSize="12" Color="#9FB4CC" Text="No target designated" />
    <Label Name="EngageLock" FontSize="12" Color="#9FB4CC" Text="LOCK none" />
    <BoxContainer Name="LockRow" Orientation="Horizontal" DrawBackground="false" Separation="5">
      <Button Name="LockButton"   Text="LOCK"   ToolTip="Lock fire-control radar on the selected contact (one lock per unit)" />
      <Button Name="UnlockButton" Text="UNLOCK" ToolTip="Release the radar lock" />
    </BoxContainer>
    <BoxContainer Name="PostureRow" Orientation="Horizontal" DrawBackground="false" Separation="5">
      <Button Name="PostureHoldButton" Text="HOLD" ToolTip="Weapons hold" />
      <Button Name="PostureDefButton"  Text="DEF"  ToolTip="Defensive: point defense only" />
      <Button Name="PostureFreeButton" Text="FREE" ToolTip="Weapons free: engage at will" />
    </BoxContainer>
    <BoxContainer Name="SalvoRow" Orientation="Horizontal" DrawBackground="false" Separation="5">
      <Button Name="SalvoDownButton" Text="-" ToolTip="Smaller salvo" />
      <Label Name="SalvoLabel" FontSize="13" Color="#CCDBEB" Text="SALVO 1" />
      <Button Name="SalvoUpButton" Text="+" ToolTip="Larger salvo" />
    </BoxContainer>
    <BoxContainer Name="WeaponList" Orientation="Vertical" DrawBackground="false" Separation="4" />
  </BoxContainer>

  <Tooltip Name="Tooltip" />

</Control>
