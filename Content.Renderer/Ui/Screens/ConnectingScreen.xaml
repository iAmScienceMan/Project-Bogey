<!-- ReSharper disable All -->
<Control xmlns="clr-namespace:Lattice.Renderer.Ui.Controls;assembly=Lattice.Renderer">

  <BoxContainer Name="Root" Orientation="Vertical" DrawBackground="false" Separation="12" HorizontalExpand="true">

    <Label Name="TitleLabel" Text="ESTABLISHING LINK" FontSize="16" Color="#F0F5F9" />
    <Rule Color="#C9D6DF" Thickness="2" />

    <BoxContainer Orientation="Horizontal" DrawBackground="false" Separation="16">
      <BoxContainer Name="IndicatorSlot" Orientation="Vertical" DrawBackground="false" />
      <BoxContainer Orientation="Vertical" DrawBackground="false" Separation="6" HorizontalExpand="true">
        <Label Name="AddressLabel" Text="" FontSize="14" Color="#C9D6DF" />
        <Label Name="StatusLabel" Text="Establishing connection" FontSize="12" Color="#8B98A1" />
      </BoxContainer>
    </BoxContainer>

    <Rule Color="#454F55" Thickness="1" />

    <BoxContainer Name="SearchingButtons" Orientation="Horizontal" DrawBackground="false">
      <Button Name="CancelButton" Text="CANCEL" FontSize="13" MinWidth="300" Negative="true" HorizontalExpand="true" />
    </BoxContainer>

    <BoxContainer Name="LostButtons" Orientation="Horizontal" DrawBackground="false" Separation="10" Visible="false">
      <Button Name="RetryButton" Text="RETRY" FontSize="13" MinWidth="145" HorizontalExpand="true" />
      <Button Name="BackButton" Text="BACK" FontSize="13" MinWidth="145" Negative="true" HorizontalExpand="true" />
    </BoxContainer>

  </BoxContainer>

</Control>
