<!-- ReSharper disable All -->
<Control xmlns="clr-namespace:Lattice.Renderer.Ui.Controls;assembly=Lattice.Renderer">

  <BoxContainer Anchor="Center" Orientation="Vertical" DrawBackground="false" Separation="16">

    <Label Name="TitleLabel" Text="PROJECT BOGEY" FontSize="40" Color="#73D9FF" />
    <Label Name="SubtitleLabel" Text="fog-of-war tactical sim" FontSize="13" Color="#9EAECC" />

    <PanelContainer>
      <BoxContainer Orientation="Vertical" DrawBackground="false" Separation="8" Padding="18">

        <GridContainer Columns="2" Separation="10" HorizontalExpand="true">
          <Label Text="USERNAME" FontSize="14" Color="#CCDBEB" />
          <LineEdit Name="UsernameEdit" MinWidth="140" FontSize="14" PlaceHolder="Bogeyman" HorizontalExpand="true" />
          <Label Text="SERVER ADDRESS" FontSize="14" Color="#CCDBEB" />
          <LineEdit Name="AddressEdit" MinWidth="140" FontSize="14" PlaceHolder="ip or ip:port" HorizontalExpand="true" />
        </GridContainer>

        <Label Name="ErrorLabel" FontSize="12" Color="#F06B62" Text="" />

        <Button Name="ConnectButton" Text="CONNECT" FontSize="16" MinWidth="300" HorizontalExpand="true" />
        <Button Name="ChangelogButton" Text="CHANGELOG" FontSize="16" MinWidth="300" HorizontalExpand="true" />
        <Button Name="OptionsButton" Text="OPTIONS" FontSize="16" MinWidth="300" HorizontalExpand="true" />
        <Button Name="QuitButton" Text="QUIT" FontSize="16" MinWidth="300" Negative="true" HorizontalExpand="true" />

      </BoxContainer>
    </PanelContainer>

  </BoxContainer>

  <Label Name="VersionLabel" Anchor="BottomRight" Margin="0 0 12 10" FontSize="11" Color="#7788AA"
         Text="build 0.1.0-dev" />

</Control>
